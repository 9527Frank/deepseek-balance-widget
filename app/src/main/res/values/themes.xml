<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base dark theme -->
    <style name="Theme.DeepSeekBalance" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">#FF4A9EFF</item>
        <item name="colorPrimaryDark">#FF2A7ADF</item>
        <item name="colorAccent">#FF4A9EFF</item>
        <item name="android:statusBarColor">#FF1A1A2E</item>
        <item name="android:navigationBarColor">#FF1A1A2E</item>
        <item name="android:windowBackground">#FF1A1A2E</item>
        <item name="android:colorBackground">#FF1A1A2E</item>
    </style>

    <!-- Configuration activity theme (dialog-style for widget config flow) -->
    <style name="Theme.DeepSeekBalance.Config" parent="Theme.DeepSeekBalance">
        <item name="android:windowIsFloating">false</item>
        <item name="android:windowAnimationStyle">@style/WidgetConfigAnimation</item>
    </style>

    <style name="WidgetConfigAnimation" parent="@android:style/Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@android:anim/fade_in</item>
        <item name="android:activityOpenExitAnimation">@android:anim/fade_out</item>
        <item name="android:activityCloseEnterAnimation">@android:anim/fade_in</item>
        <item name="android:activityCloseExitAnimation">@android:anim/fade_out</item>
    </style>
</resources>
